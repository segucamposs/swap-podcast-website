# ─── Supabase ──────────────────────────────────────────────
# Get these from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # server-side only, never expose

# ─── Cron (sync-episode-links) ──────────────────────────────
CRON_SECRET=your-cron-secret-here

# ─── Episode link sync ───────────────────────────────────────
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
YOUTUBE_API_KEY=your-youtube-api-key

# ─── Mercado Pago (merch branch only) ──────────────────────
MP_ACCESS_TOKEN=your-mercado-pago-access-token        # TEST_... for sandbox, APP_USR_... for prod

# ─── Site (merch branch only) ───────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000             # https://swap-podcast.vercel.app in prod

# ─── Admin (merch branch only) ──────────────────────────────
ADMIN_EMAILS=your-admin@email.com                     # comma-separated list of allowed admin emails
